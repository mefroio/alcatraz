2796 IFJ=15THENPRINT#1,"Firme. Daria um bom cabo.":RETURN
2798 IFJ=16THENPRINT#1,"Improvisada, mas letal.":RETURN
2800 IFJ=17THENPRINT#1,"Comprida. Aguentaria seu peso.":RETURN
2802 IFJ=18THENPRINT#1,"Um seixo pesado. Bom arremesso.":RETURN
2804 IFJ=19THENPRINT#1,"Comprida e firme.":RETURN
2806 IFJ=20THENPRINT#1,"Rede de pesca com chumbadas.":RETURN
2808 IFJ=21THENPRINT#1,"Estreito. Da' passagem para forado bloco.":RETURN
2810 IFJ=22ANDX(16)=1THENPRINT#1,"Circuito fechado. O portao ao   lado perdeu a energia.":RETURN
2812 IFJ=22THENPRINT#1,"Soquete do fusivel vazio. O     portao ao lado zumbe, eletrico.":RETURN
2814 IFJ=23THENPRINT#1,"A trava fica no alto, fora do   alcance das maos.":RETURN
2816 IFJ=24THENPRINT#1,"Desencapado, vibrando. Nao      encoste sem isolamento.":RETURN
2818 IFJ=25ANDX(19)=1THENPRINT#1,"Com a antena, alcanca a         frequencia da manutencao.":RETURN
2820 IFJ=25THENPRINT#1,"O radio de servico esta' sem    antena.":RETURN
2822 IFJ=27THENPRINT#1,"Sao de aco muito resistente.":RETURN
2824 IFJ=29THENPRINT#1,"Firme, cravado na laje. Boa     ancoragem.":RETURN
2826 IFJ=30THENPRINT#1,"Varre o costao em ciclos. Um    arremesso certeiro o apagaria.":RETURN
2828 IFJ=31THENPRINT#1,"Funda demais para saltar.":RETURN
2830 IFJ=32THENPRINT#1,"Atracada, motor ligado. O pilotoespera a manutencao.":RETURN
2832 IFJ=33THENPRINT#1,"Gelado e traicoeiro. Ninguem    escapa a nado.":RETURN
2900 PRINT#1,"E' comum.":RETURN
2920 IFJ<>26THENPRINT#1,"So' uma pessoa com sua mentali- dade diria tal coisa.":RETURN
2930 PRINT#1,"Voce foi morto. Ele nao gosta deameacas.":GOTO1430
2940 IFJ<21THENPRINT#1,"Ok... Esta' feito...":GOTO1590
2950 PRINT#1,"Nao da'.":RETURN
